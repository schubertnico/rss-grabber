{
    "name": "schubertmedia/rss-grabber",
    "description": "RSS Grabber free v2.0 – PHP 8.5 / UTF-8",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.5",
        "ext-mysqli": "*",
        "ext-simplexml": "*",
        "ext-iconv": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload-dev": {
        "psr-4": {
            "RssGrabber\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --no-progress"
    }
}
